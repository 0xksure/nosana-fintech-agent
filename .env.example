# Nosana Configuration
NOSANA_API_KEY=your_nosana_api_key_here
NOSANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
NOSANA_WALLET_PATH=/path/to/wallet.json

# ElizaOS Configuration  
ELIZAOS_LOG_LEVEL=info

# Optional: Custom Resource Limits
NOSANA_MAX_CONCURRENT_JOBS=10
NOSANA_POLL_INTERVAL=5000
NOSANA_DEFAULT_CPU=2
NOSANA_DEFAULT_MEMORY=4Gi