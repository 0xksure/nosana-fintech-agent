{
  "version": "1.0.0",
  "job": {
    "name": "financegpt-nosana-agent",
    "description": "FinanceGPT - Advanced Personal Financial Assistant for DeFi and Traditional Investing",
    "image": "financegpt:latest",
    "environment": {
      "OPENAI_API_KEY": "nosana",
      "OPENAI_API_URL": "https://5i8frj7ann99bbw9gzpprvzj2esugg39hxbb4unypskq.node.k8s.prd.nos.ci/v1",
      "MODEL_NAME": "Qwen3.5-9B-FP8",
      "OPENAI_EMBEDDING_URL": "https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1",
      "OPENAI_EMBEDDING_API_KEY": "nosana",
      "OPENAI_EMBEDDING_MODEL": "Qwen3-Embedding-0.6B",
      "OPENAI_EMBEDDING_DIMENSIONS": "1024",
      "SERVER_PORT": "3000",
      "NODE_ENV": "production",
      "DEFILLAMA_API_URL": "https://api.llama.fi",
      "ETHEREUM_RPC_URL": "https://eth.llamarpc.com",
      "POLYGON_RPC_URL": "https://polygon.llamarpc.com",
      "ARBITRUM_RPC_URL": "https://arb1.arbitrum.io/rpc"
    },
    "ports": [
      {
        "containerPort": 3000,
        "protocol": "TCP",
        "public": true,
        "name": "web-interface"
      }
    ],
    "resources": {
      "cpu": "1000m",
      "memory": "2Gi",
      "gpu": "0"
    },
    "storage": [
      {
        "name": "agent-data",
        "mountPath": "/app/data",
        "size": "10Gi",
        "accessMode": "ReadWriteOnce"
      }
    ],
    "healthCheck": {
      "path": "/health",
      "port": 3000,
      "initialDelaySeconds": 30,
      "periodSeconds": 10,
      "timeoutSeconds": 5,
      "failureThreshold": 3
    }
  },
  "deployment": {
    "replicas": 1,
    "strategy": "RollingUpdate",
    "maxUnavailable": 0,
    "maxSurge": 1
  },
  "metadata": {
    "labels": {
      "app": "financegpt",
      "version": "v1.0.0",
      "challenge": "nosana-elizaos-2026"
    },
    "annotations": {
      "nosana.io/description": "Advanced FinTech AI agent for portfolio management and DeFi analysis",
      "nosana.io/category": "finance",
      "nosana.io/author": "@0xksure"
    }
  }
}